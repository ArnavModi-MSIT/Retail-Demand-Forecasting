# Copy this file to .env and fill in real values.
# .env should be in .gitignore — never commit real credentials.

# ── Local Docker Postgres (matches docker-compose.yml) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_forecast
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SSLMODE=        # leave unset locally

# ── AWS RDS (uncomment and fill in when deploying) ────────────────────────────
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=retail_forecast
# DB_USER=your_rds_username
# DB_PASSWORD=your_rds_password
# DB_SSLMODE=require
